generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String   @id @default(uuid()) // Links to Supabase Auth UID
  email               String   @unique
  password            String?  // Hashed password for local auth
  role                Role     @default(CUSTOMER)
  firstName           String?
  lastName            String?
  phone               String?
  profileImageUrl     String?
  resetPasswordOtp    String?
  resetPasswordExpires DateTime?
  createdAt           DateTime @default(now())
  deletedAt           DateTime?
  
  employeeProfile Employee?
  customerProfile Customer?
  auditLogs       AuditLog[]
  tasksAssigned   Task[]   @relation("TaskAssigner")
  favorites       Favorite[]
}

enum Role {
  SUPER_ADMIN
  OWNER
  MANAGER
  INVENTORY_MANAGER
  SALES
  MARKETING
  DIGITAL_MARKETING
  CUSTOMER
}

model Employee {
  id          String @id @default(uuid())
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id])
  jobTitle    String?
  department  String?
  joiningDate DateTime @default(now())
  isActive    Boolean @default(true)
  attendances Attendance[]
  salaries    Salary[]
  deletedAt   DateTime?
  tasks       Task[]   @relation("TaskAssignee")
  baseSalary  Float?   // HR Payroll
  ctc         Float?   // Cost to Company
  pfRate      Float?   // e.g. 12.0
  pfLedger    PFLedger?
  leaveRequests LeaveRequest[]
}

model Customer {
  id          String @id @default(uuid())
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id])
  companyName String
  gstNumber   String?
  address     String?
  isVerified  Boolean @default(false) // Admin must verify before ordering
  isActive    Boolean @default(true) // Deprecated: use deletedAt
  deletedAt   DateTime?
  orders      Order[]
  inquiries   Inquiry[]
  reviews     Review[]
  
  @@index([isVerified, isActive])
}

model Supplier {
  id          String @id @default(uuid())
  name        String
  phone       String?
  email       String?
  isActive    Boolean @default(true) // Deprecated: use deletedAt
  deletedAt   DateTime?
  transactions InventoryTransaction[]
  products    Product[]
}

model Category {
  id       String @id @default(uuid())
  name     String @unique
  products Product[]
}

model Product {
  id          String   @id @default(uuid())
  sku         String?  @unique
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  name        String   // e.g., GP Thinner
  description String
  unit        String   // Packaging type: Litre, Kg, Drum, Barrel
  packageSize Float?   // e.g., 50, 25
  baseUnit    String?  // e.g., "Kg", "Litre"
  imageUrls   String[] // Array of product images
  datasheetUrl String? // Link to PDF datasheet in Supabase Storage
  casNumber   String?
  unNumber    String?
  brand       String?
  manufacturer String?
  itemForm    String?  // e.g., Liquid, Powder, Solid
  purity      String?  // e.g., 99.9%
  grade       String?  // e.g., AR, LR, Technical
  mfgDate     DateTime? // Manufacturing Date
  expiryDate  DateTime? // Expiry Date
  safetyNotes String?
  storageInstructions String?
  price       Float
  isMadeInIndia Boolean @default(false)
  
  @@index([name])
  @@index([casNumber])
  @@index([categoryId])
  @@index([deletedAt])
  isActive    Boolean  @default(true) // Deprecated: use deletedAt
  isAvailable Boolean  @default(true) // Admin toggle for availability
  deletedAt   DateTime?
  createdBy   String?  // Auditability
  updatedBy   String?  // Auditability
  
  inventory   Inventory?
  orderItems  OrderItem[]
  reviews     Review[]
  favorites   Favorite[]
  
  @@index([categoryId, isActive])
}

model Inventory {
  id           String @id @default(uuid())
  productId    String @unique
  product      Product @relation(fields: [productId], references: [id])
  quantity     Int
  minThreshold Int
  transactions InventoryTransaction[]
}

model InventoryTransaction {
  id          String   @id @default(uuid())
  inventoryId String
  inventory   Inventory @relation(fields: [inventoryId], references: [id])
  type        TransactionType // IN, OUT, ADJUSTMENT
  quantity    Int
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  remarks     String?
  createdBy   String?  // Auditability
  updatedBy   String?  // Auditability
  createdAt   DateTime @default(now())
}

enum TransactionType {
  IN
  OUT
  ADJUSTMENT
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())
}

model Inquiry {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  subject     String
  message     String
  status      InquiryStatus @default(PENDING)
  createdAt   DateTime @default(now())
}

enum InquiryStatus {
  PENDING
  RESPONDED
  CLOSED
}

model Quotation {
  id         String   @id @default(uuid())
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id])
  amount     Float
  fileUrl    String?  // Generated PDF stored in Supabase Storage
  validUntil DateTime
  status     QuoteStatus @default(DRAFT)
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

model Order {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  status     OrderStatus @default(PENDING)
  total      Float
  baseCost   Float?
  distanceKm Float?
  distanceCost Float?
  hazardousShippingCost Float?
  taxAmount  Float?
  shippingAddress String?
  orderNotes String?
  createdBy  String?  // Auditability
  updatedBy  String?  // Auditability
  items      OrderItem[]
  quotation  Quotation?
  payment    Payment?
  history    OrderStatusHistory[]
  createdAt  DateTime @default(now())
  deletedAt  DateTime?

  @@index([customerId, status])
}

enum OrderStatus {
  REQUESTED
  PENDING
  PROCESSING
  PACKAGED
  DISPATCHED
  DELIVERED
  CANCELLED
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id])
  oldStatus OrderStatus
  newStatus OrderStatus
  changedAt DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // e.g., "UPDATED_INVENTORY"
  entity    String   // e.g., "Inventory"
  entityId  String
  createdAt DateTime @default(now())
}

model Attendance {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  date       DateTime @default(now())
  status     AttendanceStatus @default(PRESENT)
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
}

model Salary {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  month      String   // e.g., "YYYY-MM"
  amount     Float    // Base amount processed
  deductions Float    @default(0)
  pfContribution Float @default(0)
  netPay     Float    @default(0)
  absentDays Int      @default(0)
  status     SalaryStatus @default(PENDING)
  paymentMethod String? // "CASH" or "DIGITAL_TRANSFER"
  confirmedByEmployee Boolean @default(false)
  confirmedAt DateTime?
  paidAt     DateTime?
}

enum SalaryStatus {
  PENDING
  PAID
}

model PFLedger {
  id                String   @id @default(uuid())
  employeeId        String   @unique
  employee          Employee @relation(fields: [employeeId], references: [id])
  balance           Float    @default(0)
  lastUpdatedMonth  String?  // "YYYY-MM" of last contribution
  settledAt         DateTime? // Set when employee leaves & PF is disbursed
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Payment {
  id                 String   @id @default(uuid())
  orderId            String   @unique
  order              Order    @relation(fields: [orderId], references: [id])
  paymentMethod      String   // e.g., "razorpay", "bank_transfer"
  razorpayOrderId    String?
  razorpayPaymentId  String?
  razorpaySignature  String?
  amount             Float
  status             PaymentStatus @default(PENDING)
  createdAt          DateTime @default(now())
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  assignedToId String
  assignedTo   Employee @relation("TaskAssignee", fields: [assignedToId], references: [id])
  assignedById String
  assignedBy   User     @relation("TaskAssigner", fields: [assignedById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  customerId String
  customer  Customer @relation(fields: [customerId], references: [id])
  createdAt DateTime @default(now())
}

// Leave Request — Employee submits, HR approves/rejects
model LeaveRequest {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  date        DateTime
  type        LeaveType @default(FULL_DAY)
  reason      String
  status      LeaveStatus @default(PENDING)
  reviewedBy  String?  // userId of the HR/Manager who reviewed
  reviewNote  String?  // HR's note on decision
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum LeaveType {
  FULL_DAY
  HALF_DAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

// Support Tickets — Staff reports bugs or requests help
model SupportTicket {
  id          String   @id @default(uuid())
  submittedBy String   // userId
  type        TicketType @default(BUG)
  priority    TicketPriority @default(MEDIUM)
  title       String
  description String
  status      TicketStatus @default(OPEN)
  resolution  String?
  resolvedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum TicketType {
  BUG
  FEATURE_REQUEST
  DATA_ISSUE
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}
